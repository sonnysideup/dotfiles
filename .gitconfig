[alias]
  br = branch
  cf = config
  cm = commit
  co = checkout
  df = diff
  pl = pull
  ps = push
  st = status
[commit]
  verbose = true
[core]
  editor = vim
  excludesfile = ~/.gitignore
[user]
  name = Sonny Garcia
  email = sonnygarcia@icloud.com
[pull]
	rebase = false
[init]
	defaultBranch = main
[fetch]
	prune = true
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[push]
	autoSetupRemote = true
